NEXT_PUBLIC_ERP_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3001
NEXT_PUBLIC_POS_URL=http://localhost:3002

# --- API Perú (DNI / RUC / Ubigeo) ---
# Crear cuenta gratuita: https://apis.net.pe
APIS_NET_PE_TOKEN=

# --- WhatsApp fallback de pedidos ---
WHATSAPP_NUMBER=51916856842

# --- Pasarelas de pago ---
# Culqi (https://culqi.com)  o Izipay (https://izipay.pe)
CULQI_PUBLIC_KEY=
CULQI_SECRET_KEY=
IZIPAY_MERCHANT_ID=
IZIPAY_PUBLIC_KEY=
IZIPAY_HMAC_KEY=

# --- Yape / Plin (QR estático apuntando al teléfono o cuenta) ---
YAPE_QR_NUMBER=916856842
PLIN_QR_NUMBER=916856842

# --- Facturación electrónica SUNAT ---
# Opción 1 — PSE/OSE (recomendado): Nubefact
SUNAT_PSE_PROVIDER=nubefact
NUBEFACT_RUC=
